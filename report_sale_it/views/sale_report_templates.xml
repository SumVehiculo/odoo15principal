<?xml version="1.0" encoding="utf-8"?>
<odoo>
    

    <template id="report_saleorder_document">
        <t t-call="web.external_layout">

            <div class="header">
                        <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
                        <div class="row pt-2" style="font-family: Arial;font-size:11px">
                            <div class="col-8 pt-0 row">
                                <div class="col-4">
                                    <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)"
                                                     alt="Logo" style="width: 150px; top: 0 ; vertical-align: baseline;"
                                                     class="mt-0 pt-0"
                                                />

                                </div>
                                <div class="col-8">
                                    <span class="font-weight-bold" t-field="doc.company_id.name"/><br/>
                                    <span class="text-left" t-if="doc.company_id.vat">R.U.C. </span><span t-if="doc.company_id.vat" t-field="doc.company_id.vat"/><br t-if="doc.company_id.vat"  />
                                                <!-- <span class="text-left">Direcciòn Fiscal: </span> -->
                                    <span class="text-left "  t-if="doc.company_id.partner_id.contact_address" t-field="doc.company_id.partner_id.contact_address"/><br t-if="doc.partner_id.contact_address"  />
                                    <span class="text-right" t-if="doc.company_id.email" t-field="doc.company_id.email"/><br  t-if="doc.company_id.email" />
                                    <span class="text-right" t-if="doc.company_id.phone" t-field="doc.company_id.phone"/><br  t-if="doc.company_id.phone" />

                                </div>


                            </div>
                            <div class="col-4 pt-0" >
                                <div class="text-center p-2 font-weight-bold"
                                     style="font-size:20px; border: 1px solid gray; background-color :  rgba(188,205,197,0.30)">
                                                    <p>
                                                       <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                                                           <span t-if="doc.state not in ['draft','sent']"  >ORDEN Nº:  </span>
                                                           <span t-if="doc.state in ['draft','sent']" >COTIZACIÓN Nº: </span>
                                                       </t>
                                                       <t t-if="env.context.get('proforma', False) or is_pro_forma">
                                                           <span>Pro-Forma Invoice # </span>
                                                       </t>
                                                        <br/>
                                                    </p>
                                                    <p style="font-size:30px">
                                                       <span t-field="doc.name"/>
                                                    </p>
                                </div>
                            </div>
                        </div>
            </div>
            


            <div class="page" style="font-family: Arial;font-size:12px">
                <div class="oe_structure"/>

                <div class="row pt-2" >
                    <div  class="col-7" >
                        <div  class="row" >
                            <div  class="col-3 " >
                                <p  class="m-0 p-1"><span class="font-weight-bold">Cliente:</span> </p>
                            </div>
                            <div  class="col-9 " >
                                <p  class="m-0 p-1"><span  t-field="doc.partner_id.name"/></p>
                            </div>
                        </div>
                        <div  class="row" >
                            <div  class="col-3 " >
                                <p  class="m-0 p-1"><span class="font-weight-bold">RUC:</span> </p>
                            </div>
                            <div  class="col-9 " >
                                <p  class="m-0 p-1"><span  t-field="doc.partner_id.vat"/></p>
                            </div>
                        </div>
                        <div  class="row" >
                            <div  class="col-3 " >
                                <p  class="m-0 p-1"><span class="font-weight-bold">Dirección:</span> </p>
                            </div>
                            <div  class="col-9 " >
                                <p  class="m-0 p-1"><span  t-field="doc.partner_id.contact_address"/></p>
                            </div>
                        </div>

                    </div>
                    <div class="col-5">
                        <div  class="row" >
                            <div  class="col-5 " >
                                <p  class="m-0 p-1"><span class="font-weight-bold">Fecha Validez: </span></p>
                            </div>
                            <div  class="col-7 " >
                                <p  class="m-0 p-1"><span  t-field="doc.validity_date" /></p>
                            </div>
                        </div>
                        <div  class="row" >
                            <div  class="col-5 " >
                                <p  class="m-0 p-0"><span class="font-weight-bold">Fecha Emisión:</span> </p>
                            </div>
                            <div  class="col-7 " >
                                <p  class="m-0 p-1"><span  t-field="doc.date_order"  t-options='{"format": "dd/MM/yyyy"}' /></p>
                            </div>
                        </div>
                        <div  class="row" >
                            <div  class="col-5 " >
                                <p  class="m-0 p-1"><span class="font-weight-bold">Plazos de Pago: </span></p>
                            </div>
                            <div  class="col-7 " >
                                <p  class="m-0 p-1"><span  t-field="doc.payment_term_id.name" /></p>
                            </div>
                        </div>
                        <div  class="row" >
                            <div  class="col-5 " >
                                <p  class="m-0 p-1"><span class="font-weight-bold">Vendedor: </span></p>
                            </div>
                            <div  class="col-7 " >
                                <p  class="m-0 p-1"><span  t-field="doc.user_id.name"/></p>
                            </div>
                        </div>
                        <div  class="row" >
                            <div  class="col-5 " >
                                <p  class="m-0 p-1"><span class="font-weight-bold">Telf : </span></p>
                            </div>
                            <div  class="col-7 " >
                                <p  class="m-0 p-1"><span  t-field="doc.user_id.phone"/>
                                    <span class="ml-2 mr-2" t-if="not doc.user_id.mobile" >/</span>
                                    <span  t-field="doc.user_id.mobile"/>
                                </p>
                            </div>
                        </div>
                        <div  class="row" t-if="doc.user_id.email">
                            <div  class="col-5 " >
                                <p  class="m-0 p-1"><span class="font-weight-bold">E-mail : </span></p>
                            </div>
                            <div  class="col-7 " >
                                <p  class="m-0 p-1"><span  t-field="doc.user_id.email"/></p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Is there a discount on at least one line? -->
                <t t-set="display_discount" t-value="any(l.discount for l in doc.order_line)"/>

                <table class="table table-sm o_main_table">
                    <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                    <thead style="display: table-row-group">
                        <tr>
                            <th name="th_code_product"
                                style="  width: 10% !important;"
                                class="text-left">Cod. Articulo</th>
                            <th name="th_description" class="text-center">Descripción</th>
                            <th name="th_um" class="text-right">UM</th>
                            <th name="th_quantity" class="text-right">Cant.</th>
                                groups="product.group_discount_per_so_line">
                                <span>Desc.%</span>
                            </th>
                            <!--<th name="th_taxes" class="text-right">Impuestos</th> -->
                            <th name="th_subtotal" class="text-right">
                                Total
                            </th>
                        </tr>
                    </thead>
                    <tbody class="sale_tbody">

                        <t t-set="current_subtotal" t-value="0"/>

                        <t t-foreach="doc.order_line" t-as="line">

                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                            <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="not line.display_type">
                                    <td name="td_code_product"
                                        style="padding: 3px !important; margin: 0px !important;"  >
                                        <t t-if="line.product_id">
                                            <span t-field="line.product_id.default_code"/>
                                        </t>
                                    </td>
                                    <td name="td_name" style="padding: 3px !important; margin: 0px !important;"  ><span t-field="line.name"/></td>
                                    <td name="td_um" style="padding: 3px !important; margin: 0px !important;" ><span t-field="line.product_uom"/></td>
                                    <td name="td_quantity" class="text-right" style="padding: 3px !important; margin: 0px !important;" >
                                        <span t-field="line.product_uom_qty" t-options='{"widget": "float", "precision": 2}' />
                                    </td>
                                    <!--
                                    <td name="td_taxes" class="text-right">
                                        <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                    </td>
                                    -->
                                    <td name="td_subtotal" class="text-right o_price_total" style="padding: 3px !important; margin: 0px !important;" >
                                        <span t-field="line.price_subtotal"
                                              t-options='{"widget": "float", "precision": 2}'
                                              groups="account.group_show_line_subtotals_tax_excluded"/>
                                        <span t-field="line.price_total"
                                              t-options='{"widget": "float", "precision": 2}'
                                              groups="account.group_show_line_subtotals_tax_included"/>
                                    </td>
                                </t>
                            </tr>

                        </t>
                    </tbody>
                </table>

                <div class="clearfix" name="so_total_summary">
                    <div id="total" class="row" name="total">
                        <div t-attf-class="#{'col-4' if report_type != 'html' else 'col-sm-7 col-md-5'} ml-auto">
                            <table class="table table-sm">
                                <!-- Tax totals -->
                                <t t-set="tax_totals" t-value="json.loads(doc.tax_totals_json)"/>
                                <t t-call="account.document_tax_totals"/>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="oe_structure"/>
                <p t-field="doc.note" />
            </div>
            <div class="footer">
                <div class="oe_structure"/>
                Pie pequeño
            </div>
        </t>
    </template>

    <template id="sale.report_saleorder">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="report_sale_it.report_saleorder_document" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>


    <record id="paperformat_id_cp" model="report.paperformat">
            <field name="name">Purchase Order Report</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">297</field>
            <field name="page_width">210</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">15</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">25</field>
            <field name="dpi">90</field>
    </record>

    <report
            id="sale.action_report_saleorder"
            string="Quotation / Order"
            model="sale.order"
            report_type="qweb-pdf"
            file="sale.report_saleorder"
            name="sale.report_saleorder"
            print_report_name="(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name)) or 'Order - %s' % (object.name)"
            paperformat="report_sale_it.paperformat_id_cp"
    />

</odoo>