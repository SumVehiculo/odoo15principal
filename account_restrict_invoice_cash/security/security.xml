<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.module.category" id="module_account_restrict_invoice_cash">
            <field name="name">Registros Contabilidad</field>
            <field name="sequence">61</field>
            <field name="visible" eval="0" />
        </record>
        <record id="group_invoice_only" model="res.groups">
            <field name="name">Usuario: Solo Mostrar sus propios Documentos</field>
            <field name="category_id" ref="module_account_restrict_invoice_cash"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_invoice_all" model="res.groups">
            <field name="name">Usuario: Mostrar Todos los documentos</field>
            <field name="category_id" ref="module_account_restrict_invoice_cash"/>
            <field name="implied_ids" eval="[(4, ref('group_invoice_only'))]"/>
        </record>

        <record id="sale_order_personal_rule" model="ir.rule">
            <field name="name">Registros Personales</field>
            <field ref="account.model_account_move" name="model_id"/>
            <field name="domain_force">['|',('create_uid','=',create_uid.id),('create_uid','=',False)]</field>
            <field name="groups" eval="[(4, ref('account_restrict_invoice_cash.group_invoice_only'))]"/>
        </record>

    </data>
</odoo>
