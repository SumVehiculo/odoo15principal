<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
    

    <template id="report_purchase_order_document">
            <div class="header">
                        <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
                        <div class="row pt-2" style="font-family: Arial;font-size:11px">
                            <div class="col-12 pt-0 row">
                                <div class="col-6">
                                    <center><img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)"
                                                     alt="Logo" style="width: 150px; top: 0 ; vertical-align: baseline;"
                                                     class="mt-0 pt-0"
                                                /></center>
                                                <center>CSI - Av Alfonso Ugarte N 521 - Arequipa - Tlf.<br/>
                                                (054)281728 - Fax (054)201288 </center>

                                </div>
                                <div class="col-8">
                                    <h1><center>
                                                       <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                                                           <span t-if="doc.state not in ['draft','sent']">PEDIDO</span>
                                                           <span t-if="doc.state in ['draft','sent']" >PRESUPUESTO</span>
                                                       </t>
                                        </center>
                                    </h1>
                                </div>


                            </div>
                            <div class="col-4 pt-0" >
                            </div>
                        </div>
            </div>
            


            <div class="article o_report_layout_standard" style="font-family: Arial;font-size:12px">
                <div class="page">
                    <div class="oe_structure"/>
                        <center><h2 t-if="o.state in ['draft', 'sent', 'to approve']">SOLICITUD DE COMPRA N° <span t-field="o.name"/></h2></center>
                        <center><h2 t-if="o.state in ['purchase', 'done']">ORDEN DE COMPRA N° <span t-field="o.name"/></h2></center>
                        <center><h2 t-if="o.state == 'cancel'">ORDEN DE COMPRA CANCELADA N° <span t-field="o.name"/></h2></center>
                        <table>
                            <tbody>
                                <tr>    
                                    <td>PROVEEDOR</td>
                                    <td colspan='3'>:</td>
                                </tr>
                                <tr>    
                                    <td>RUC</td>
                                    <td colspan='3'>:</td>
                                </tr>
                                <tr>    
                                    <td>DIRECCIÓN</td>
                                    <td>:</td>
                                    <td>TELÉFONO</td>
                                    <td>:</td>
                                </tr>
                                <tr>    
                                    <td>CONTACTO</td>
                                    <td colspan='3'>:</td>
                                </tr>
                            </tbody>
                        </table>
                        <p>Por la presente orden, agradecemos dispones de los siguientes artículos según cotización</p>
                    
                    <table class="table table-sm o_main_table">
                        <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                        <thead style="display: table-row-group">
                            <tr>
                                <th name="th_code_product"
                                    style="  width: 10% !important;"
                                    class="text-left">Cod. Articulo</th>
                                <th name="th_description" class="text-center">Descripción</th>
                                <th name="th_um" class="text-right">UM</th>
                                <th name="th_quantity" class="text-right">Cant.</th>
                                <!--<th name="th_taxes" class="text-right">Impuestos</th> -->
                                <th name="th_subtotal" class="text-right">
                                    Total
                                </th>
                                <td>N°</td>
                            <td>CANTIDAD</td>
                            <td>UND MED</td>
                            <td>CODIGO</td>
                            <td>DESCRIPCIÓN</td>
                            <td>PRECIO</td>
                            <td>TOTAL</td>
                            </tr>
                        </thead>
                        <tbody class="sale_tbody">

                            <t t-set="current_subtotal" t-value="0"/>

                            <t t-foreach="doc.order_line" t-as="line">

                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                    <t t-if="not line.display_type">
                                        <td name="td_code_product"
                                            style="padding: 3px !important; margin: 0px !important;"  >
                                            <t t-if="line.product_id">
                                                <span t-field="line.product_id.default_code"/>
                                            </t>
                                        </td>
                                        <td name="td_name" style="padding: 3px !important; margin: 0px !important;"  ><span t-field="line.name"/></td>
                                        <td name="td_um" style="padding: 3px !important; margin: 0px !important;" ><span t-field="line.product_uom"/></td>
                                        <td name="td_quantity" class="text-right" style="padding: 3px !important; margin: 0px !important;" >
                                            <span t-field="line.product_uom_qty" t-options='{"widget": "float", "precision": 2}' />
                                        </td>
                                        <!--
                                        <td name="td_taxes" class="text-right">
                                            <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                        </td>
                                        -->
                                        <td name="td_subtotal" class="text-right o_price_total" style="padding: 3px !important; margin: 0px !important;" >
                                            <span t-field="line.price_subtotal"
                                                  t-options='{"widget": "float", "precision": 2}'
                                                  groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <span t-field="line.price_total"
                                                  t-options='{"widget": "float", "precision": 2}'
                                                  groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                    </t>
                                </tr>

                            </t>
                        </tbody>
                        <tfooter>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td colspan=''>SUBTOTAL</td>
                            <td></td>
                        </tr>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td colspan=''>IGV</td>
                            <td></td>
                        </tr>
                        <tr>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td colspan=''>TOTAL</td>
                            <td></td>
                        </tr>
                    </tfooter>
                    </table>
                    <table>
                    <tbody>
                        <tr>    
                            <td>MONEDA</td>
                            <td></td>
                        </tr>
                        <tr>    
                            <td>OBSERVACIONES</td>
                            <td></td>
                        </tr>
                    </tbody>
                </table>
                <table>
                    <tbody>
                        <tr>    
                            <td>FACTURAR A NOMBRE DE</td>
                            <td>:</td>
                        </tr>
                        <tr>    
                            <td>RAZON SOCIAL</td>
                            <td>:</td>
                        </tr>
                        <tr>    
                            <td>RUC</td>
                            <td>:</td>
                        </tr>
                        <tr>    
                            <td>DIRECCIÓN</td>
                            <td>:</td>
                        </tr>
                        <tr>    
                            <td>CONDICIÓN DE PAGO</td>
                            <td>:</td>
                        </tr>
                    </tbody>
                </table>
                <table>
                    <tbody>
                        <tr>    
                            <td></td>
                            <td></td>
                            <td>FECHA</td>
                            <td>:</td>
                        </tr>
                       
                    </tbody>
                </table>
                <center><h3>ESTIMADOS PROVEEDORES</h3></center>
                <p>Se les informa que la recepción de factura física en Jirón Monterrey N° 341, Interior 302, Urb Chacarilla, Surco.</p>
                <p>Tener presente que la factura física y/o electrónica debe contar con el siguiente sustento:</p>
                <p>- ORDEN DE COMPRA</p>
                <p>- NOTA DE INGRESO DEL ALMACÉN, DEBIDAMENTE FIRMADA Y SELLADA VALIDANDO LA RECEPCIÓN DEL PERSONAL DE ALMACÉN DE SUM VEHICULOS.</p>
                <p>- LA FACTURA DEBE INDICAR EL NÚMERO DE LA ORDEN DE COMPRA.</p>
                <p>- GUÍA REMISIÓN DEBIDAMENTE FIRMADA Y SELLADA VALIDANDO LA RECEPCIÓN POR EL PERSONAL DE ALMACÉN DE SUM VEHICULOS.</p>
                <p>- LA DESCRIPCIÓN DE LA FACTURA: ITEM, CANTIDAD, PRECIO UNITARIO Y TOTALES DEBEN SER IGUALES A LAS DETALLADAS EN LA ORDEN DE COMMPRA.</p>
                <p>- LAS CONDICIONES DE PAGO SE APLICARÁN A PARTIR DE LA FECHA DE RECEPCIÓN A ENTERA SATISFACCIÓN DE LA FACTURA O BOLETA DE VENTA CON EL SUSTENTO INDICADO</p>
                <p>De lunes a viernes de 8:00 a 13:00 o de 14:00 a 17:00 horas.</p>
                <p>En caso que la </p><p>Factura sea electrónica, </p><p>se debe enviar los formatos PDF y XML, junto con los documentos mencionados anteriormente (en archivos PDF) a los correos:</p>
                <p>asistente@sum.pe; compras@sum.pe</p>
                   
                </div>
            </div>
            <div class="footer">
                <div class="oe_structure"/>
                Pie pequeño
            </div>
    </template>

    <template id="purchase.report_purchaseorder">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="purchase_report.report_purchase_order_document" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>


    <record id="paperformat_id_cp" model="report.paperformat">
            <field name="name">Orden de compra</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">297</field>
            <field name="page_width">210</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">60</field>
            <field name="margin_bottom">15</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">50</field>
            <field name="dpi">90</field>
    </record>

    <record id="purchase.action_report_purchase_order" model="ir.actions.report">
            <field name="name">Orden de compra</field>
            <field name="model">purchase.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">purchase.report_purchaseorder</field>
            <field name="report_file">purchase.report_purchaseorder</field>
            <field name="print_report_name">
                (object.state in ('draft', 'sent') and 'Request for Quotation - %s' % (object.name) or
                'Purchase Order - %s' % (object.name))</field>
            <field name="binding_model_id" ref="model_purchase_order"/>
            <field name="binding_type">report</field>
        </record>


    
    </data>
    

</odoo>
